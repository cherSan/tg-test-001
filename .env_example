TG_API_KEY="TGBottoken"

# Database (SQLite)
DB_PATH= DB PATH

# HideFox VPN admin panel
AMNEZIA_SERVER_URL=URL:PROT  #if ssl use https, if not use http
AMNEZIA_ADMIN_PASSWORD= admin panel password

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=

# Support staff Telegram IDs (comma-separated) — receive ticket notifications
SUPPORT_IDS=

# Payment addresses
USDT_PAYMENT_ADDRESS=TXggxPcL5R3PwvB8qZ2myJ7mKf1W4sD6aV
BTC_PAYMENT_ADDRESS=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
GRAM_PAYMENT_ADDRESS=EQD5mxRgCuY5kF4Lm7vBqZ2myJ7mKf1W4sD6aV9xPc

# Enable/disable specific payment methods
ENABLE_BTC_PAYMENT=true
ENABLE_GRAM_PAYMENT=false

# Subscription pricing (USDT) — direct prices
# Free trial duration in hours (0 = disabled)
TRIAL_TIME=24

# Trial price in USDT (0 = free)
SUBSCRIPTION_24H_USDT=0
SUBSCRIPTION_7D_USDT=5
SUBSCRIPTION_14D_USDT=8
SUBSCRIPTION_30D_USDT=15
SUBSCRIPTION_180D_USDT=75

# Exchange for live rates: coinex or binance
EXCHANGE_API=coinex

# Anti-spam: delay between inline button clicks (ms), spam block duration (ms)
ACTION_COOLDOWN_MS=1000
SPAM_BLOCK_MS=3000

# Referral system
REFERRAL_REWARD_TYPE=usdt          # usdt or days
REFERRAL_LEVELS=0:5,10:7,30:10,50:15,100:20     # activeReferrals:percent
REFERRAL_FIRST_PURCHASE_BONUS=3   # bonus for referrer on referral's first deposit
REFERRAL_MIN_DEPOSIT=5            # min deposit to count as active referral
REFERRAL_FREE_KEY_DAYS=30         # free key for referrer without keys
REFERRAL_WINDOW_HOURS=72          # hours after registration to add a referrer

# Auto-reply to unknown messages (true = echo, false = silent)
ENABLE_AUTO_ANSWER=false

# Ticket creation cooldown in minutes (with/without active subscription)
TICKET_TIME_WITH_SUB=5
TICKET_TIME_NO_SUB=60

# Maximum open tickets per user
MAX_OPEN_TICKETS=3
MAX_OPEN_TICKETS_NO_SUB=1

# Require subscription/balance for ticket creation
ENABLE_TICKET_ONLY_SUB=false

# Ticket validation: topic length (min-max) and message length (min-max)
TICKET_TOPIC_MIN=3
TICKET_TOPIC_MAX=10
TICKET_MSG_MIN=10
TICKET_MSG_MAX=400

# Auto-close tickets after support reply (hours)
ENABLE_AUTO_CLOSE_TICKET=true
AUTO_CLOSE_TICKET_TIME_AFTER_ANSWER=48
